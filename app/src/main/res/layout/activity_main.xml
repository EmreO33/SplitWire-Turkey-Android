<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="32dp"
    android:paddingVertical="24dp"
    tools:context=".activities.MainActivity">

    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp">

        <View
            android:id="@+id/status_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_status_ring"
            android:backgroundTint="@color/status_disconnected" />

        <ImageView
            android:id="@+id/status_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_power_24"
            app:tint="@color/status_disconnected" />
    </FrameLayout>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:textSize="26sp"
        android:textStyle="bold"
        tools:text="@string/vpn_disconnected" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/status_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:alpha="0.7"
        android:gravity="center"
        android:textSize="14sp"
        tools:text="@string/status_sub_disconnected" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/proxy_address"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:alpha="0.55"
        android:fontFamily="monospace"
        android:textSize="13sp"
        tools:text="127.0.0.1:1080" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/status_button"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/brand_red"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:cornerRadius="29dp"
        tools:text="@string/vpn_connect" />

</LinearLayout>
